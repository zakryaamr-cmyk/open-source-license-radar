---
import Layout from '../layouts/Layout.astro';
import licenseData from '../../data/licenses.json';
---

<Layout title="Open-Source License Fallback Radar">
    <div class="max-w-6xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
        <header class="mb-12 text-center">
            <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight mb-4">Open-Source License Fallback Radar</h1>
            <p class="text-lg text-gray-600 max-w-2xl mx-auto">Tracking popular open-source projects shifting to restrictive licenses and identifying free alternatives.</p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {licenseData.shifts.map((shift) => (
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow duration-200 flex flex-col overflow-hidden">
                    <div class="p-6 flex-grow">
                        <div class="flex justify-between items-start mb-4">
                            <div>
                                <h2 class="text-2xl font-bold text-gray-900">{shift.original_name}</h2>
                                <p class="text-sm text-gray-500 font-mono mt-1">{shift.original_owner}/{shift.original_name}</p>
                            </div>
                            <span class="inline-flex items-center bg-gray-50 text-gray-700 text-xs font-semibold px-2.5 py-1 rounded-md border border-gray-200">
                                <svg class="w-3.5 h-3.5 mr-1 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                                </svg>
                                {shift.original_stars ? shift.original_stars.toLocaleString() : 'N/A'}
                            </span>
                        </div>

                        <div class="mb-6 bg-gray-50 rounded-lg p-4 border border-gray-100">
                            <h3 class="text-xs uppercase tracking-wider text-gray-500 font-bold mb-3">License Shift</h3>
                            <div class="flex items-center text-sm font-medium">
                                <span class="text-green-800 bg-green-100 px-2.5 py-1 rounded-md">{shift.old_license || 'OSI-Approved'}</span>
                                <svg class="w-5 h-5 mx-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                                </svg>
                                <span class="text-red-800 bg-red-100 px-2.5 py-1 rounded-md">{shift.new_restrictive_license || 'Restrictive'}</span>
                            </div>
                        </div>

                        {shift.free_fork_name && (
                            <div class="mb-2">
                                <h3 class="text-xs uppercase tracking-wider text-gray-500 font-bold mb-2">Top Free Alternative</h3>
                                <div class="flex items-center justify-between bg-white border border-gray-100 rounded-md p-3">
                                    <span class="font-mono text-sm text-gray-800 font-medium">{shift.free_fork_name}</span>
                                    <span class="text-xs text-gray-500 flex items-center">
                                        <svg class="w-3 h-3 mr-1 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                                        </svg>
                                        {shift.free_fork_stars ? shift.free_fork_stars.toLocaleString() : 'N/A'}
                                    </span>
                                </div>
                            </div>
                        )}
                    </div>
                    
                    <div class="bg-gray-50 px-6 py-4 border-t border-gray-100 mt-auto">
                        <a href={`/open-source-license-radar/migrate-${shift.original_name.toLowerCase()}-alternative`} class="w-full inline-flex justify-center items-center px-4 py-2 text-sm font-bold text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors shadow-sm">
                            Migration Guide & Alternatives
                            <svg class="w-4 h-4 ml-2" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 10">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 5h12m0 0L9 1m4 4L9 9"/>
                            </svg>
                        </a>
                    </div>
                </div>
            ))}
        </div>
    </div>
</Layout>