---
import Layout from '../layouts/Layout.astro';
import licenseData from '../../data/licenses.json';
---

<Layout title="Open-Source License Fallback Radar">
    <div class="max-w-6xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
        
        <!-- Direct Support & Sponsorship Navigation -->
        <div class="flex justify-end gap-3 mb-8">
            <a href="mailto:your-email@example.com" class="px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-md text-sm font-bold hover:bg-gray-50 shadow-sm transition-colors">Advertise Here</a>
            <a href="https://github.com/sponsors/zakryaamr-cmyk" target="_blank" class="px-4 py-2 bg-gray-900 text-white rounded-md text-sm font-bold hover:bg-gray-800 shadow-sm transition-colors">Support this Project</a>
        </div>

        <header class="mb-10 text-center">
            <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight mb-4">Open-Source License Fallback Radar</h1>
            <p class="text-lg text-gray-600 max-w-2xl mx-auto">Tracking popular open-source projects shifting to restrictive licenses and identifying free alternatives.</p>
        </header>

        <div class="max-w-xl mx-auto mb-10">
            <input type="text" id="searchInput" placeholder="Filter by project name or license (e.g., redis, sspl-1.0)..." class="w-full px-4 py-3 rounded-lg border border-gray-300 shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" />
        </div>

        <!-- Primary Ad Slot (High Value) -->
        <div class="mb-10 bg-blue-50 border border-blue-200 rounded-xl p-6 text-center">
            <span class="text-xs font-black text-blue-500 uppercase tracking-widest block mb-2">Sponsored</span>
            <h3 class="text-lg font-bold text-blue-900 mb-1">Scale without Vendor Lock-in</h3>
            <p class="text-sm text-blue-800 mb-4">Migrating from restrictive licenses? Use our managed open-source database clusters.</p>
            <a href="#" class="inline-block bg-blue-600 text-white font-bold py-2 px-6 rounded hover:bg-blue-700 transition-colors">Claim $100 Cloud Credits</a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6" id="projectsGrid">
            {licenseData.shifts.map((shift) => (
                <div class="project-card bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow duration-200 flex flex-col overflow-hidden" data-name={shift.original_name.toLowerCase()} data-license={shift.new_restrictive_license?.toLowerCase() || ''}>
                    <div class="p-6 flex-grow">
                        <div class="flex justify-between items-start mb-4">
                            <div>
                                <h2 class="text-2xl font-bold text-gray-900">{shift.original_name}</h2>
                                <p class="text-sm text-gray-500 font-mono mt-1">{shift.original_owner}/{shift.original_name}</p>
                            </div>
                            <span class="inline-flex items-center bg-gray-50 text-gray-700 text-xs font-semibold px-2.5 py-1 rounded-md border border-gray-200">
                                {shift.original_stars ? shift.original_stars.toLocaleString() : 'N/A'} Stars
                            </span>
                        </div>

                        <div class="mb-6 bg-gray-50 rounded-lg p-4 border border-gray-100">
                            <h3 class="text-xs uppercase tracking-wider text-gray-500 font-bold mb-3">License Shift</h3>
                            <div class="flex items-center text-sm font-medium">
                                <span class="text-green-800 bg-green-100 px-2.5 py-1 rounded-md">{shift.old_license || 'OSI-Approved'}</span>
                                <span class="mx-3 text-gray-400">&rarr;</span>
                                <span class="text-red-800 bg-red-100 px-2.5 py-1 rounded-md">{shift.new_restrictive_license || 'Restrictive'}</span>
                            </div>
                        </div>

                        {shift.free_fork_name && (
                            <div class="mb-2">
                                <h3 class="text-xs uppercase tracking-wider text-gray-500 font-bold mb-2">Top Free Alternative</h3>
                                <div class="flex items-center justify-between bg-white border border-gray-100 rounded-md p-3">
                                    <span class="font-mono text-sm text-gray-800 font-medium">{shift.free_fork_name}</span>
                                    <span class="text-xs text-gray-500 font-semibold">{shift.free_fork_stars ? shift.free_fork_stars.toLocaleString() : 'N/A'} Stars</span>
                                </div>
                            </div>
                        )}
                    </div>
                    
                    <div class="bg-gray-50 px-6 py-4 border-t border-gray-100 mt-auto">
                        <a href={`/open-source-license-radar/migrate-${shift.original_name.toLowerCase()}-alternative`} class="w-full inline-flex justify-center items-center px-4 py-2 text-sm font-bold text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors shadow-sm">
                            Migration Guide & Alternatives &rarr;
                        </a>
                    </div>
                </div>
            ))}
        </div>
    </div>

    <script>
        const searchInput = document.getElementById('searchInput');
        const cards = document.querySelectorAll('.project-card');

        searchInput.addEventListener('input', (e) => {
            const term = e.target.value.toLowerCase();
            cards.forEach(card => {
                const name = card.getAttribute('data-name');
                const license = card.getAttribute('data-license');
                if (name.includes(term) || license.includes(term)) {
                    card.style.display = 'flex';
                } else {
                    card.style.display = 'none';
                }
            });
        });
    </script>
</Layout>