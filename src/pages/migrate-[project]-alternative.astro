---
import Layout from '../layouts/Layout.astro';
import licenseData from '../../data/licenses.json';

export function getStaticPaths() {
  return licenseData.shifts.map((shift) => ({
    params: { project: shift.original_name.toLowerCase() },
    props: { shift },
  }));
}

const { shift } = Astro.props;
const affiliateLink = import.meta.env.AFFILIATE_LINK || "https://m.do.co/c/your_referral_code_here";
---

<Layout title={`Migrate from ${shift.original_name} to ${shift.free_fork_name}`}>
  <div class="max-w-4xl mx-auto py-12 px-4">
    <a href="/open-source-license-radar/" class="text-blue-600 font-bold hover:underline mb-8 inline-block">&larr; Return to Radar</a>
    
    <h1 class="text-4xl font-extrabold mb-4 text-gray-900">Migration Guide: {shift.original_name} &rarr; {shift.free_fork_name}</h1>
    
    <div class="bg-red-50 border-l-4 border-red-500 p-6 mb-8 rounded-r-lg">
        <h2 class="font-bold text-red-900 mb-2">License Shift Alert</h2>
        <p class="text-red-800"><strong>{shift.original_name}</strong> transitioned from <strong>{shift.old_license}</strong> to <strong>{shift.new_restrictive_license}</strong>. Commercial usage may now require paid licensing.</p>
    </div>

    <div class="bg-white border border-gray-200 p-8 rounded-xl mb-8 shadow-sm">
        <h2 class="text-2xl font-bold mb-4 text-gray-900">Recommended OSS Alternative: {shift.free_fork_name}</h2>
        <p class="mb-6 text-gray-600 text-lg">A community-maintained drop-in replacement operating under the <strong>{shift.free_fork_license || 'open-source'}</strong> license.</p>
        
        <a href={shift.free_fork_url} target="_blank" class="inline-block bg-gray-900 text-white px-6 py-3 rounded-lg font-bold hover:bg-gray-800 transition-colors">View Repository</a>
    </div>

    <!-- Affiliate Monetization Section -->
    <div class="bg-gradient-to-br from-blue-700 to-indigo-900 p-10 rounded-2xl text-center shadow-xl">
        <span class="bg-blue-500 text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider mb-4 inline-block">Partner Offer</span>
        <h2 class="text-3xl font-extrabold text-white mb-4">Deploy {shift.free_fork_name} in One Click</h2>
        <p class="text-blue-100 mb-8 text-lg max-w-2xl mx-auto">Avoid local configuration overhead. Spin up a secure, managed instance of {shift.free_fork_name} on enterprise-grade cloud infrastructure instantly.</p>
        <a href={affiliateLink} target="_blank" class="inline-block bg-white text-blue-800 px-10 py-4 rounded-xl font-black text-lg hover:bg-blue-50 transition-colors shadow-lg">Start Free Cloud Trial</a>
        <p class="text-xs text-blue-300 mt-6 font-medium">* This link supports the maintenance of Open-Source License Radar via affiliate commission at no extra cost to you.</p>
    </div>
  </div>
</Layout>