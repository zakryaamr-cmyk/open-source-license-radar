---
import Layout from '../layouts/Layout.astro';
import licenseData from '../../data/licenses.json';

export async function getStaticPaths() {
    return licenseData.shifts.map((shift) => ({
        params: { project: shift.original_name.toLowerCase() },
        props: { shift },
    }));
}

const { shift } = Astro.props;
---

<Layout title={`Migrate from ${shift.original_name} - Alternatives & Guide`}>
    <div class="max-w-4xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
        <a href="/open-source-license-radar/" class="inline-flex items-center text-sm font-medium text-blue-600 hover:text-blue-800 mb-8 transition-colors">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Back to Radar
        </a>

        <div class="mb-10">
            <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight mb-3">Migrate from {shift.original_name}</h1>
            <p class="text-lg text-gray-600">A complete breakdown of the license shift and open-source alternatives.</p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
            <div class="bg-white p-6 rounded-xl border border-gray-200 shadow-sm">
                <h2 class="text-sm uppercase tracking-wider text-gray-500 font-bold mb-4">The Shift</h2>
                <ul class="space-y-3 text-sm">
                    <li class="flex justify-between border-b border-gray-100 pb-2">
                        <span class="text-gray-600">Repository</span>
                        <span class="font-mono font-medium">{shift.original_owner}/{shift.original_name}</span>
                    </li>
                    <li class="flex justify-between border-b border-gray-100 pb-2">
                        <span class="text-gray-600">Old License</span>
                        <span class="font-medium text-green-700">{shift.old_license || 'OSI-Approved'}</span>
                    </li>
                    <li class="flex justify-between pb-2">
                        <span class="text-gray-600">New License</span>
                        <span class="font-bold text-red-700">{shift.new_restrictive_license}</span>
                    </li>
                </ul>
            </div>

            {shift.free_fork_name ? (
                <div class="bg-blue-50 p-6 rounded-xl border border-blue-100 shadow-sm">
                    <h2 class="text-sm uppercase tracking-wider text-blue-800 font-bold mb-4">Top Open-Source Alternative</h2>
                    <ul class="space-y-3 text-sm">
                        <li class="flex justify-between border-b border-blue-200/50 pb-2">
                            <span class="text-blue-800">Fork Name</span>
                            <a href={shift.free_fork_url} target="_blank" rel="noopener noreferrer" class="font-mono font-bold text-blue-900 hover:underline">{shift.free_fork_name}</a>
                        </li>
                        <li class="flex justify-between border-b border-blue-200/50 pb-2">
                            <span class="text-blue-800">License</span>
                            <span class="font-medium text-blue-900">{shift.free_fork_license}</span>
                        </li>
                        <li class="flex justify-between pb-2">
                            <span class="text-blue-800">Community Stars</span>
                            <span class="font-medium text-blue-900">{shift.free_fork_stars.toLocaleString()}</span>
                        </li>
                    </ul>
                </div>
            ) : (
                <div class="bg-gray-50 p-6 rounded-xl border border-gray-200 shadow-sm flex items-center justify-center">
                    <p class="text-gray-500 font-medium text-center">No active open-source forks detected yet.</p>
                </div>
            )}
        </div>
    </div>
</Layout>