---
interface Props { title: string; }
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
</head>
<body class="bg-gray-50 text-gray-900 font-sans p-8">
    <main class="max-w-4xl mx-auto"><slot /></main>
</body>
</html>